        "    lora_dropout        = LORA_DROPOUT,\n",
        "    target_modules      = [\n",
        "        \"q_proj\",   # Query projection\n",
        "        \"k_proj\",   # Key projection\n",
        "        \"v_proj\",   # Value projection\n",
        "        \"o_proj\",   # Output projection\n",
        "        \"gate_proj\",# FFN gate\n",
        "        \"up_proj\",  # FFN up\n",
        "        \"down_proj\",# FFN down\n",
