        "    model_name    = BASE_MODEL,\n",
        "    max_seq_length= MAX_SEQ_LEN,\n",
        "    dtype         = None,\n",
        "    load_in_4bit  = True,\n",
        ")\n",
        "\n",
        "print(f\"✅ Base model loaded: {BASE_MODEL}\")\n",
        "print(f\"   Parameters: ~8 Billion\")\n",
        "print(f\"   Quantization: 4-bit NF4 (QLoRA)\")\n",
        "print(f\"   Dtype: {model.dtype}\")"
      ]
