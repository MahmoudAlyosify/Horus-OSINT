          "name": "stdout",
          "text": [
            "✅ Template defined. No double-EOS bug.\n",
            "   EOS token: '<|eot_id|>'\n",
            "\n",
            "=== Sample formatted prompt ===\n",
            "<|begin_of_text|><|start_header_id|>system<|end_header_id|>\n",
            "You are Horus, an elite Intelligence Analyst specializing in Open-Source Intelligence (OSINT). You synthesize tactical incident data (GTD) with macro-geopolitical event volumes (GDELT) to provide holistic threat assessments.<|eot_id|><|start_header_id|>user<|end_header_id|>\n",
            "Provide a brief intelligence summary of the Unarmed Assault incident that occurred in Yemen during 2017.<|eot_id|><|start_header_id|>assistant<|end_header_id|>\n",
            "INTELLIGENCE REPORT — UNARMED ASSAULT | Yemen | 2017\n",
            "\n",
            "According to GTD records, a Unarmed Assault incident took place in Yemen during 2017, resulting in approximately 1 reported fatality and 1 wounded.\n",
            "The ...\n"
          ]
        }
      ],
      "source": [
        "# Llama-3 Instruct format — must match exactly what PySpark produced\n",
        "LLAMA3_TEMPLATE = \"\"\"\\\n",
        "<|begin_of_text|><|start_header_id|>system<|end_header_id|>\n",
        "{system}<|eot_id|><|start_header_id|>user<|end_header_id|>\n",
        "{instruction}<|eot_id|><|start_header_id|>assistant<|end_header_id|>\n",
        "{response}<|eot_id|>\"\"\"\n",
        "\n",
        "SYSTEM_PROMPT = (\n",
        "    \"You are Horus, an elite Intelligence Analyst specializing in Open-Source \"\n",
        "    \"Intelligence (OSINT). You synthesize tactical incident data (GTD) with \"\n",
        "    \"macro-geopolitical event volumes (GDELT) to provide holistic threat assessments.\"\n",
        ")\n",
        "\n",
        "EOS_TOKEN = tokenizer.eos_token  # <|eot_id|> for Llama-3\n",
        "\n",
        "def format_sample(sample):\n",
        "    \"\"\"\n",
        "    Formats a JSONL sample into the Llama-3 instruct template.\n",
        "    Keys expected: instruction (required), output (required),\n",
        "                   system (optional), input (optional context).\n",
        "    \"\"\"\n",
        "    system      = sample.get(\"system\", SYSTEM_PROMPT)\n",
        "    instruction = sample[\"instruction\"]\n",
        "    if sample.get(\"input\", \"\").strip():\n",
        "        instruction = f\"{instruction}\\n\\nContext: {sample['input']}\"\n",
        "    response = sample[\"output\"]\n",
        "\n",
        "    # Appending it again would create <|eot_id|><|eot_id|> (double stop token)\n",
        "    text = LLAMA3_TEMPLATE.format(\n",
        "        system      = system,\n",
        "        instruction = instruction,\n",
        "        response    = response,\n",
        "    )\n",
        "    return {\"text\": text}\n",
        "\n",
        "# Sanity check on a real data sample\n",
        "test_sample = {\n",
        "    \"system\": SYSTEM_PROMPT,\n",
        "    \"instruction\": \"Provide a brief intelligence summary of the Unarmed Assault incident that occurred in Yemen during 2017.\",\n",
        "    \"input\": \"\",\n",
        "    \"output\": \"INTELLIGENCE REPORT — UNARMED ASSAULT | Yemen | 2017\\n\\nAccording to GTD records, a Unarmed Assault incident took place in Yemen during 2017, resulting in approximately 1 reported fatality and 1 wounded.\\nThe incident primarily targeted Private Citizens & Property.\\nThe perpetrators utilized Vehicle (not to include vehicle-borne explosives, i.e., car or truck bombs).\\nResponsibility was attributed to Houthi extremists (Ansar Allah).\\n\\nGEOPOLITICAL CONTEXT: Concurrent GDELT analysis recorded 107,464 geopolitical events linked to Yemen in 2017, indicating an elevated operational tempo.\\n\\nTHREAT ASSESSMENT: This incident is consistent with patterns of low-severity terrorism activity. Continued monitoring of Yemen is recommended.\"\n",
        "}\n",
        "formatted = format_sample(test_sample)[\"text\"]\n",
        "assert not formatted.endswith(\"<|eot_id|><|eot_id|>\"), \"❌ Double EOS detected!\"\n",
        "print(\"✅ Template defined. No double-EOS bug.\")\n",
        "print(f\"   EOS token: {repr(EOS_TOKEN)}\")\n",
        "print(\"\\n=== Sample formatted prompt ===\")\n",
        "print(formatted[:700], \"...\")\n"
      ]
    },
