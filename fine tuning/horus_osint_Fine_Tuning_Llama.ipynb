        "## Section 11 — Upload GGUF to S3\n",
        "The GGUF file is uploaded to S3 so the EC2 deployment step (Section 6) can\n",
        "download it without Colab staying connected."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "upload-s3",
      "metadata": {
        "id": "upload-s3",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "a1582869-128c-467a-e513-e7e912c4fe31"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "⬆️  Uploading GGUF to s3://horus-25bbdf-g23-bucket/models/horus-llama3-osint-Q4_K_M.gguf ...\n",
            "    File size: 4.92 GB — this may take a few minutes.\n",
            "\n",
            "✅ Upload complete!\n",
            "   S3 URI: s3://horus-25bbdf-g23-bucket/models/horus-llama3-osint-Q4_K_M.gguf\n",
            "\n",
            "Next step — EC2 download command:\n",
            "   aws s3 cp s3://horus-25bbdf-g23-bucket/models/horus-llama3-osint-Q4_K_M.gguf ./horus-llama3-osint.gguf\n"
          ]
        }
      ],
      "source": [
        "import boto3\n",
        "import os\n",
        "\n",
        "# 1. المسار الحقيقي للملف اللي ظهر عندك\n",
        "gguf_file = \"/content/horus-llama3-osint_gguf/llama-3-8b-instruct.Q4_K_M.gguf\"\n",
        "size_gb = os.path.getsize(gguf_file) / 1e9\n",
        "\n",
        "\n",
        "MY_ACCESS_KEY = \"\"\n",
        "MY_SECRET_KEY = \"\"\n",
        "MY_SESSION_TOKEN = \"\"\n",
        "\n",
        "# Re-init S3 client with fresh credentials\n",
        "s3 = boto3.client(\n",
        "    \"s3\",\n",
        "    region_name=AWS_REGION,\n",
        "    aws_access_key_id=MY_ACCESS_KEY,\n",
        "    aws_secret_access_key=MY_SECRET_KEY,\n",
        "    aws_session_token=MY_SESSION_TOKEN\n",
        ")\n",
        "\n",
        "print(f\"⬆️  Uploading GGUF to s3://{S3_BUCKET}/{S3_MODEL_KEY} ...\")\n",
        "print(f\"    File size: {size_gb:.2f} GB — this may take a few minutes.\")\n",
        "\n",
        "# Upload with progress callback\n",
        "uploaded_bytes = {\"n\": 0}\n",
        "total_bytes    = os.path.getsize(gguf_file)\n",
        "\n",
        "def progress(chunk):\n",
        "    uploaded_bytes[\"n\"] += chunk\n",
        "    pct = 100 * uploaded_bytes[\"n\"] / total_bytes\n",
        "    print(f\"   {pct:.1f}%\", end=\"\\r\")\n",
        "\n",
        "s3.upload_file(\n",
        "    gguf_file,\n",
        "    S3_BUCKET,\n",
        "    S3_MODEL_KEY,\n",
        "    Callback=progress,\n",
        ")\n",
        "\n",
        "print(f\"\\n Upload complete!\")\n",
        "print(f\"   S3 URI: s3://{S3_BUCKET}/{S3_MODEL_KEY}\")\n",
        "print()\n",
        "print(\"Next step — EC2 download command:\")\n",
        "print(f'   aws s3 cp s3://{S3_BUCKET}/{S3_MODEL_KEY} ./horus-llama3-osint.gguf')"
      ]
    },
